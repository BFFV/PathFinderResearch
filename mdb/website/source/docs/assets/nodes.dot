graph {
  {
    node [ shape=plain fontcolor=black fontsize=10]
    authorl [ pos="0,0.4!" label="Author" ]
    bookl   [ pos="1,0.4!" label="Book"]
  }

  {
    node [ fixedsize=shape fontcolor=black fontsize=10 width=0.5 shape=circle style=filled]
    author  [ pos="0,0!" fillcolor=lightgreen label=""]
    book    [ pos="1,0!" fillcolor=lightblue label=""]
  }
}
